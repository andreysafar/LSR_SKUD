# LSR_SKUD Environment Configuration Template
# Copy this file to .env and customize for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_PATH=data/gate_control.db

# =============================================================================
# ANPR BATCH PROCESSING CONFIGURATION  
# =============================================================================

# Input directories (comma-separated)
ANPR_INPUT_DIRECTORIES=/mnt/iss_media/CAM_14,/mnt/iss_media/CAM_16,/mnt/iss_media/CAM_18

# Worker configuration
ANPR_CPU_WORKERS=8
ANPR_GPU_WORKERS=4
ANPR_FFMPEG_GPU_WORKERS=2

# Video processing settings
ANPR_VIDEO_EXTENSION=.issvd
ANPR_FRAME_SKIP=10
ANPR_CONFIDENCE_THRESHOLD=0.25

# Output paths
ANPR_OUTPUT_CSV_PATH=data/plates.csv
ANPR_OUTPUT_IMAGES_DIR=data/snapshots

# Performance optimization
ANPR_FORMAT_CACHE_ENABLED=true
ANPR_TIMEOUT_SECONDS=120
ANPR_PROCESS_TIMEOUT=3600

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
MODELS_DIR=models
TORCHSCRIPT_ENABLED=true
HALF_PRECISION=true

# Recognition confidence thresholds
CONFIDENCE_VEHICLE=0.5
CONFIDENCE_PLATE=0.5
CONFIDENCE_OCR=0.4

# =============================================================================
# GPU CONFIGURATION
# =============================================================================
GPU_ENABLED=true
DEVICE=cuda
CUDA_VISIBLE_DEVICES=all

# =============================================================================
# TELEGRAM BOT CONFIGURATION (Optional)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
ADMIN_CHAT_ID=your_admin_chat_id
TECH_CHAT_ID=your_tech_chat_id

# =============================================================================
# PARSEC INTEGRATION (Optional)
# =============================================================================
PARSEC_DOMAIN=your.parsec.domain.com
PARSEC_PORT=10101
PARSEC_ORGANIZATION=SYSTEM
PARSEC_BOT_USERNAME=bot_user
PARSEC_BOT_PASSWORD=bot_password
PARSEC_ADMIN_USERNAME=admin_user
PARSEC_ADMIN_PASSWORD=admin_password

# =============================================================================
# STREAMLIT CONFIGURATION
# =============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
ANPR_LOG_FILE=batch_processing/process_videos.log
ANPR_PID_FILE=batch_processing/process_videos.pid
ANPR_MAX_LOG_SIZE_MB=100
ANPR_LOG_ROTATION_COUNT=5

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
ANPR_HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
PERFORMANCE_MONITORING=true

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=production

# Container configuration
CONTAINER_TIMEZONE=Europe/Moscow
CONTAINER_USER_ID=1000
CONTAINER_GROUP_ID=1000

# Security
SECURE_MODE=true
SSL_ENABLED=false

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# Redis (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Prometheus (for monitoring)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Grafana (for visualization)  
GRAFANA_ENABLED=false
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# DEVELOPMENT SETTINGS (Development only)
# =============================================================================
DEBUG=false
DEVELOPMENT_MODE=false
HOT_RELOAD=false

# Test data
TEST_DATA_DIR=tests/data
CREATE_TEST_DATA=false
TEST_FILE_COUNT=50